# Google Sheets API — path to service account JSON key file
# Create at: https://console.cloud.google.com/ → IAM → Service Accounts
# Share the spreadsheet with the service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_FILE=~/.config/vendor-tracker/service-account.json

# Or use OAuth2 credentials file instead:
# GOOGLE_OAUTH_CREDENTIALS_FILE=~/.config/vendor-tracker/credentials.json

# Spreadsheet ID (from the URL of your Google Sheet)
SPREADSHEET_ID=1vVhrW3j2aKXT5_UaaxYY6ZIZ673a9vO2iHmsIiNBED0

# Vendor portal credentials
PFG_USERNAME=
PFG_PASSWORD=
SYSCO_USERNAME=
SYSCO_PASSWORD=
USFOODS_USERNAME=
USFOODS_PASSWORD=
